{
  "name": "pachinko",
  "version": "1.1.0",
  "description": "Policy engine and web UI (monorepo root — application lives in /server)",
  "private": true,
  "workspaces": [
    "server"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "toolvault": "./dist/toolvault"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TeamSparkAI/pachinko.git"
  },
  "author": "TeamSpark, LLC <support@teamspark.ai>",
  "license": "SEE LICENSE IN LICENSE.md",
  "keywords": [
    "ai",
    "agent",
    "mcp",
    "tools",
    "security",
    "policy",
    "teamspark"
  ],
  "bugs": {
    "url": "https://github.com/TeamSparkAI/pachinko/issues"
  },
  "homepage": "https://github.com/TeamSparkAI/pachinko#readme",
  "scripts": {
    "build": "node scripts/build.js",
    "build:next": "npm run build:next --workspace=server",
    "build:bundle": "npm run build:bundle --workspace=server",
    "build:prod": "npm run build:prod --workspace=server",
    "start": "node dist/server.js",
    "start:prod": "node dist/server.js",
    "start:dev": "npm run start:dev --workspace=server",
    "start:server": "./dist/toolvault",
    "migrate": "npm run migrate --workspace=server",
    "test": "npm run test --workspace=server",
    "test:watch": "npm run test:watch --workspace=server",
    "test:coverage": "npm run test:coverage --workspace=server",
    "test:e2e": "npm run test:e2e --workspace=server",
    "load-sample-data": "npm run load-sample-data --workspace=server",
    "clean": "npm run clean --workspace=server"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "files": [
    "dist/"
  ]
}
